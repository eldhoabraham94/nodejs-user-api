# Database — set DB_TYPE to 'better-sqlite3' (no setup required) or 'mysql'
DB_TYPE=better-sqlite3
DB_NAME=./dev.db

# Only needed when DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=secret

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h

# Initial admin seed (used by: npm run seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
